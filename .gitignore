# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# playwright MCP logs
.playwright-mcp/

# supabase temp/local state
supabase/.temp/

# cursor IDE
.cursor/

# Python virtualenvs and caches (selfie-worker, redistribuicao-worker, etc.)
**/.venv/
**/__pycache__/
**/*.pyc

# Claude Code local artifacts
.agents/
.claude/scheduled_tasks.lock
.claude/skills/

# Random screenshots accidentally saved into source
src/lib/Captura de tela*.png

# Seed scripts that contain API secrets (never commit)
scripts/seed-sync-keys-*.ts
