      "x": 45,
      "y": 935,
      "width": 590,
      "height": 28,
      "text": "🧠 A IA estuda o tema ANTES de consultar as personas",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#fa5252",
