    {
      "id": "analise_title",
      "type": "text",
      "x": 45,
      "y": 3145,
      "width": 590,
      "height": 28,
      "text": "🎯 A IA Mais Poderosa Analisa os Dados (Claude Opus)",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#f783ac",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
