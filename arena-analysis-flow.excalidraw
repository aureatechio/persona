    {
      "id": "classify_title",
      "type": "text",
      "x": 45,
      "y": 1915,
      "width": 590,
      "height": 28,
      "text": "⚡ Como a IA decide a opinião de cada persona",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1601,
      "version": 1,
      "versionNonce": 1601,
      "isDeleted": false,
