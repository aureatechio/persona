    {
      "id": "platform_title",
      "type": "text",
      "x": 680,
      "y": 3145,
      "width": 580,
      "height": 28,
      "text": "As recomendações mudam por plataforma:",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#f783ac",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
