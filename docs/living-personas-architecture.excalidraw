    },

    {
      "id": "flow2-label",
      "type": "text",
      "x": 20,
      "y": 900,
      "width": 700,
      "height": 25,
      "text": "FLUXO 2: Pergunta no Arena com sentimentos vivos",
      "fontSize": 18,
