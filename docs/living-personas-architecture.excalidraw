    {
      "id": "newtables-text",
      "type": "text",
      "x": 785,
      "y": 150,
      "width": 390,
      "height": 240,
      "text": "6 NOVAS TABELAS SUPABASE\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\ncandidates\n  id, name, party, leaning, photo_url\n  polling_percent, sentiment_trend, is_active\n\npersona_sentiments (DINAMICA - escala p/ N)\n  persona_id + candidate_id (PK composta)\n  sentiment (-1.0 a +1.0) + initial_sentiment\n\nnews_events (cache p/ Arena tambem)\n  headline, summary, candidate_id\n  impact_analysis (jsonb), magnitude, direction\n\nsentiment_updates (auditoria completa)\nupdate_cycles (snapshot_id -> rollback)\npolling_anchors (pesquisas reais Datafolha etc)",
